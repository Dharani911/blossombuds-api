    <!-- Seed WhatsApp template: New Arrivals Campaign -->
    <changeSet id="0033-10-seed-template-new-arrivals-campaign" author="dharani">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM whatsapp_templates
                WHERE provider_template_name = 'new_arrivals_campaign'
                AND language_code = 'en'
            </sqlCheck>
        </preConditions>
        <insert tableName="whatsapp_templates">
            <column name="name" value="New Arrivals Campaign"/>
            <column name="provider_template_name" value="new_arrivals_campaign"/>
            <column name="category" value="MARKETING"/>
            <column name="language_code" value="en"/>
            <column name="body_preview" value="Hi {{1}}, new floral collections are now available at Blossom Buds. Explore our latest designs here: {{2}}"/>
            <column name="variable_count" valueNumeric="2"/>
            <column name="active" valueBoolean="true"/>
            <column name="created_by" value="liquibase"/>
            <column name="created_at" valueDate="NOW()"/>
            <column name="modified_by" value="liquibase"/>
