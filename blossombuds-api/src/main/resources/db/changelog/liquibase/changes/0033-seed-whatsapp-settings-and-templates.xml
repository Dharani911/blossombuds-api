    <!-- WhatsApp Cloud API: enabled flag. Keep false for dry-run mode. -->
    <changeSet id="0033-01-seed-whatsapp-cloud-enabled" author="dharani">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM settings WHERE key = 'whatsapp.cloud.enabled'
            </sqlCheck>
        </preConditions>
        <insert tableName="settings">
            <column name="key" value="whatsapp.cloud.enabled"/>
            <column name="value" value="false"/>
            <column name="active" valueBoolean="true"/>
            <column name="created_by" value="liquibase"/>
            <column name="created_at" valueDate="NOW()"/>
            <column name="modified_by" value="liquibase"/>
            <column name="modified_at" valueDate="NOW()"/>
        </insert>
        <rollback>
            <delete tableName="settings">
                <where>key = 'whatsapp.cloud.enabled'</where>
            </delete>
        </rollback>
    </changeSet>

