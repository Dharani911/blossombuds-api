<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0031-01-add-gst-fields-to-orders" author="dharani">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="orders" columnName="taxable_amount"/>
            </not>
        </preConditions>

        <addColumn tableName="orders">
            <column name="taxable_amount" type="numeric(12,2)" defaultValueNumeric="0.00"/>
            <column name="gst_rate" type="numeric(5,2)" defaultValueNumeric="0.00"/>
            <column name="gst_amount" type="numeric(12,2)" defaultValueNumeric="0.00"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>