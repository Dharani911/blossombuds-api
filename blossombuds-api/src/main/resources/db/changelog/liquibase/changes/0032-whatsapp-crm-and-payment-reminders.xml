<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0032-01-create-customer-whatsapp-preferences" author="dharani">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="customer_whatsapp_preferences"/>
            </not>
        </preConditions>

        <createTable tableName="customer_whatsapp_preferences">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="customer_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="phone" type="varchar(30)">
                <constraints nullable="false"/>
            </column>

            <column name="opted_in" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="source" type="varchar(50)"/>
            <column name="opted_in_at" type="timestamptz"/>
            <column name="opted_out_at" type="timestamptz"/>
            <column name="last_consent_text" type="text"/>

            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="created_by" type="varchar(100)"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="modified_by" type="varchar(100)"/>
            <column name="modified_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="customer_whatsapp_preferences"
                baseColumnNames="customer_id"
                referencedTableName="customers"
                referencedColumnNames="id"
                constraintName="fk_customer_whatsapp_preferences_customer"/>

        <createIndex tableName="customer_whatsapp_preferences"
                     indexName="ux_customer_whatsapp_preferences_customer"
                     unique="true">
            <column name="customer_id"/>
        </createIndex>

        <createIndex tableName="customer_whatsapp_preferences"
                     indexName="idx_customer_whatsapp_preferences_opted_in">
            <column name="opted_in"/>
            <column name="active"/>
        </createIndex>
    </changeSet>

    <changeSet id="0032-02-create-whatsapp-templates" author="dharani">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="whatsapp_templates"/>
            </not>
        </preConditions>

        <createTable tableName="whatsapp_templates">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>

            <column name="provider_template_name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>

            <column name="category" type="varchar(30)">
                <constraints nullable="false"/>
            </column>

            <column name="language_code" type="varchar(20)" defaultValue="en">
                <constraints nullable="false"/>
            </column>

            <column name="body_preview" type="text"/>
            <column name="variable_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="created_by" type="varchar(100)"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="modified_by" type="varchar(100)"/>
            <column name="modified_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="whatsapp_templates"
                     indexName="ux_whatsapp_templates_provider_name_lang"
                     unique="true">
            <column name="provider_template_name"/>
            <column name="language_code"/>
        </createIndex>

        <createIndex tableName="whatsapp_templates"
                     indexName="idx_whatsapp_templates_active_category">
            <column name="active"/>
            <column name="category"/>
        </createIndex>
    </changeSet>

    <changeSet id="0032-03-create-whatsapp-campaigns" author="dharani">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="whatsapp_campaigns"/>
            </not>
        </preConditions>

        <createTable tableName="whatsapp_campaigns">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="title" type="varchar(200)">
                <constraints nullable="false"/>
            </column>

            <column name="template_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="audience_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="varchar(40)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>

            <column name="scheduled_at" type="timestamptz"/>
            <column name="started_at" type="timestamptz"/>
            <column name="completed_at" type="timestamptz"/>

            <column name="total_recipients" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="sent_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="failed_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="delivered_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="read_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="notes" type="text"/>

            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="created_by" type="varchar(100)"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="modified_by" type="varchar(100)"/>
            <column name="modified_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="whatsapp_campaigns"
                baseColumnNames="template_id"
                referencedTableName="whatsapp_templates"
                referencedColumnNames="id"
                constraintName="fk_whatsapp_campaigns_template"/>

        <createIndex tableName="whatsapp_campaigns"
                     indexName="idx_whatsapp_campaigns_status">
            <column name="status"/>
            <column name="active"/>
        </createIndex>

        <createIndex tableName="whatsapp_campaigns"
                     indexName="idx_whatsapp_campaigns_created_at">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="0032-04-create-whatsapp-campaign-recipients" author="dharani">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="whatsapp_campaign_recipients"/>
            </not>
        </preConditions>

        <createTable tableName="whatsapp_campaign_recipients">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="campaign_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="customer_id" type="bigint"/>
            <column name="phone" type="varchar(30)">
                <constraints nullable="false"/>
            </column>

            <column name="recipient_name" type="varchar(200)"/>
            <column name="status" type="varchar(40)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>

            <column name="provider_message_id" type="varchar(200)"/>
            <column name="error_message" type="text"/>
            <column name="variables_json" type="text"/>

            <column name="queued_at" type="timestamptz"/>
            <column name="sent_at" type="timestamptz"/>
            <column name="delivered_at" type="timestamptz"/>
            <column name="read_at" type="timestamptz"/>
            <column name="failed_at" type="timestamptz"/>

            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="created_by" type="varchar(100)"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="modified_by" type="varchar(100)"/>
            <column name="modified_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="whatsapp_campaign_recipients"
                baseColumnNames="campaign_id"
                referencedTableName="whatsapp_campaigns"
                referencedColumnNames="id"
                constraintName="fk_whatsapp_campaign_recipients_campaign"/>

        <addForeignKeyConstraint
                baseTableName="whatsapp_campaign_recipients"
                baseColumnNames="customer_id"
                referencedTableName="customers"
                referencedColumnNames="id"
                constraintName="fk_whatsapp_campaign_recipients_customer"/>

        <createIndex tableName="whatsapp_campaign_recipients"
                     indexName="idx_whatsapp_campaign_recipients_campaign_status">
            <column name="campaign_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex tableName="whatsapp_campaign_recipients"
                     indexName="idx_whatsapp_campaign_recipients_provider_message">
            <column name="provider_message_id"/>
        </createIndex>

        <createIndex tableName="whatsapp_campaign_recipients"
                     indexName="idx_whatsapp_campaign_recipients_phone">
            <column name="phone"/>
        </createIndex>
    </changeSet>

    <changeSet id="0032-05-create-whatsapp-message-events" author="dharani">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="whatsapp_message_events"/>
            </not>
        </preConditions>

        <createTable tableName="whatsapp_message_events">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="provider_message_id" type="varchar(200)"/>
            <column name="phone" type="varchar(30)"/>

            <column name="event_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <column name="provider_status" type="varchar(50)"/>
            <column name="raw_payload" type="text"/>
            <column name="error_code" type="varchar(100)"/>
            <column name="error_message" type="text"/>

            <column name="received_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="whatsapp_message_events"
                     indexName="idx_whatsapp_message_events_provider_message">
            <column name="provider_message_id"/>
        </createIndex>

        <createIndex tableName="whatsapp_message_events"
                     indexName="idx_whatsapp_message_events_received_at">
            <column name="received_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="0032-06-create-payment-reminders" author="dharani">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="payment_reminders"/>
            </not>
        </preConditions>

        <createTable tableName="payment_reminders">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="checkout_intent_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="customer_id" type="bigint"/>
            <column name="channel" type="varchar(30)">
                <constraints nullable="false"/>
            </column>

            <column name="phone" type="varchar(30)"/>
            <column name="email" type="varchar(255)"/>

            <column name="status" type="varchar(40)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>

            <column name="provider_message_id" type="varchar(200)"/>
            <column name="error_message" type="text"/>

            <column name="scheduled_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="sent_at" type="timestamptz"/>
            <column name="failed_at" type="timestamptz"/>

            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="created_by" type="varchar(100)"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="modified_by" type="varchar(100)"/>
            <column name="modified_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="payment_reminders"
                baseColumnNames="checkout_intent_id"
                referencedTableName="checkout_intent"
                referencedColumnNames="id"
                constraintName="fk_payment_reminders_checkout_intent"/>

        <addForeignKeyConstraint
                baseTableName="payment_reminders"
                baseColumnNames="customer_id"
                referencedTableName="customers"
                referencedColumnNames="id"
                constraintName="fk_payment_reminders_customer"/>

        <createIndex tableName="payment_reminders"
                     indexName="idx_payment_reminders_status_schedule">
            <column name="status"/>
            <column name="scheduled_at"/>
            <column name="active"/>
        </createIndex>

        <createIndex tableName="payment_reminders"
                     indexName="idx_payment_reminders_checkout_intent">
            <column name="checkout_intent_id"/>
        </createIndex>

        <createIndex tableName="payment_reminders"
                     indexName="idx_payment_reminders_provider_message">
            <column name="provider_message_id"/>
        </createIndex>
    </changeSet>


</databaseChangeLog>