<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        expo_outreach template — used for contacts imported from expos/events who have
        NOT registered on the platform. Includes mandatory opt-out instruction since
        these contacts cannot opt out via a profile page.

        Meta template body (must match exactly what is approved in WhatsApp Business Manager):
        "Hi {{1}}, 🌸 {{2}} Shop our collection: {{3}} — Reply STOP to unsubscribe."

        Variables: {{1}} name, {{2}} offer/message text, {{3}} link
    -->
    <changeSet id="0041-01-seed-template-expo-outreach" author="dharani">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM bb_app.whatsapp_templates WHERE provider_template_name = 'expo_outreach'
            </sqlCheck>
        </preConditions>
        <insert tableName="whatsapp_templates" schemaName="bb_app">
            <column name="name"                   value="Expo Outreach"/>
            <column name="provider_template_name" value="expo_outreach"/>
            <column name="category"               value="MARKETING"/>
            <column name="language_code"          value="en"/>
            <column name="body_preview"           value="Hi {{1}}, 🌸 {{2}} Shop our collection: {{3}} — Reply STOP to unsubscribe."/>
            <column name="variable_count"         valueNumeric="3"/>
            <column name="active"                 valueBoolean="true"/>
            <column name="created_by"             value="system"/>
            <column name="created_at"             valueComputed="NOW()"/>
            <column name="modified_by"            value="system"/>
            <column name="modified_at"            valueComputed="NOW()"/>
        </insert>
        <rollback>
            DELETE FROM bb_app.whatsapp_templates WHERE provider_template_name = 'expo_outreach';
        </rollback>
    </changeSet>

</databaseChangeLog>
